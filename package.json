{
  "name": "voxcode-ai-extension",
  "displayName": "voxcode-ai-extension",
  "description": "Voice-powered AI coding assistant for VS Code that converts speech into executable code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onCommand:voxcode.openPanel"],
  
  "main": "./extension.js",
  "contributes": {
    "commands": [
        {
            "command": "voxcode.openPanel",
            "title": "Open Voice Panel",
            "category": "VoxCode"
        }
    ],
    "configuration": {
        "title": "VoxCode AI",
        "properties": {
            "voxcode.serverUrl": {
                "type": "string",
                "default": "http://localhost:5000",
                "description": "Base URL of the VoxCode AI server."
            }
        }
    }
},

  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "node-fetch": "^2.7.0"
  }
}
